# Environment Configuration for SashaInfinity LMS

# Environment
ENVIRONMENT=development
DEBUG=True

# Database
DATABASE_URL=postgresql://tutor_user:tutor_password@postgres:5432/tutor_lms

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long
JWT_SECRET=your-jwt-secret-change-in-production-must-be-secure
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3030", "https://yourdomain.com"]

# Email / SMTP Configuration
# For your VPS email server with RoundCube
SMTP_HOST=mail.yoursubdomain.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yoursubdomain.yourdomain.com
SMTP_PASSWORD=your_email_password
EMAIL_FROM=SashaInfinity LMS <noreply@yoursubdomain.yourdomain.com>

# Alternative SMTP settings:
# For SSL/TLS on port 465, use SMTP_SSL instead of SMTP with STARTTLS
# SMTP_PORT=465

# Payment (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=["jpg", "jpeg", "png", "gif", "pdf", "mp4", "mov", "avi", "mkv"]

# URLs
FRONTEND_URL=httpsL//lms.sashainfinity.com
BACKEND_URL=https://backend.sashainfinity.com/api/v1
DOMAIN=sashainfinity.com

# Logging
LOG_LEVEL=INFO
